							"let request_object = {\r",
							"    name : name_s_request,\r",
							"    salary : salary_s_request,\r",
							"    age : age_s_request\r",
							"}\r",
							"pm.test(\"Name,Age,Salary\", function () {\r",
							"    pm.expect(response).to.deep.eql(request_object);\r",
							"    \r",
							"});\r",
							"\r",
